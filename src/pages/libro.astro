---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const libro = (await getCollection('opera'))
  .filter(o => o.data.collection === 'libro')
  .sort((a,b) => a.data.order - b.data.order);
---

<BaseLayout title="Libro — Tecnofascismo · Ayman Soliman" description="Un'indagine narrativa sul tecnofascismo contemporaneo">
  <section class="collection-hero">
    <div class="container-editorial">
      <span class="eyebrow">Progetto lungo</span>
      <h1>Libro — Tecnofascismo</h1>
      <p class="lead">
        Un'indagine narrativa e analitica sul tecnofascismo contemporaneo, scritta in dialogo tra Ayman Soliman e PI.
        Capitoli, ricerche e appendici che Compongono un'opera collettiva umano-AI in continua evoluzione.
      </p>
    </div>
  </section>

  <section class="opere-list container-editorial">
    {libro.map(opera => (
      <a href={`/opera/${opera.id}`} class="opera-row">
        <div class="row-num">{String(opera.data.order).padStart(2, '0')}</div>
        <div class="row-img">
          <img src={opera.data.cover} alt={opera.data.title} loading="lazy" />
        </div>
        <div class="row-body">
          <h2>{opera.data.title}</h2>
          <p class="row-sub">{opera.data.subtitle}</p>
        </div>
        <div class="row-arrow">→</div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
.collection-hero {
  padding: 8rem 0 4rem;
  text-align: center;
  background:
    radial-gradient(ellipse at center, rgba(201,169,97,0.05) 0%, transparent 60%),
    var(--color-ink);
}
.eyebrow {
  display: inline-block;
  font-family: var(--font-display);
  font-style: italic;
  color: var(--color-gold);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  font-size: 0.85rem;
  margin-bottom: 1rem;
}
.collection-hero h1 {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  margin: 0 0 1.5rem;
  color: var(--color-paper);
}
.lead {
  max-width: 56ch;
  margin: 0 auto;
  font-size: 1.2rem;
  line-height: 1.7;
  color: var(--color-paper-soft);
}

.opere-list {
  padding: 2rem 1.5rem 6rem;
}
.opera-row {
  display: grid;
  grid-template-columns: auto 200px 1fr auto;
  align-items: center;
  gap: 2rem;
  padding: 2rem 0;
  border-bottom: 1px solid rgba(201,169,97,0.1);
  text-decoration: none;
  transition: padding-left 0.3s ease;
}
.opera-row:hover {
  padding-left: 1rem;
}
.opera-row:hover .row-arrow {
  transform: translateX(8px);
  color: var(--color-gold-bright);
}
.opera-row:hover .row-img img {
  filter: brightness(1) saturate(1.15);
}
.row-num {
  font-family: var(--font-display);
  font-size: 2.5rem;
  color: var(--color-gold);
  opacity: 0.5;
  font-style: italic;
}
.row-img {
  width: 200px;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  border-radius: 3px;
}
.row-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.8);
  transition: filter 0.4s ease, transform 0.5s ease;
}
.opera-row:hover .row-img img { transform: scale(1.05); }
.row-body h2 {
  font-family: var(--font-display);
  font-size: 2rem;
  color: var(--color-paper);
  margin: 0 0 0.3rem;
  line-height: 1.1;
}
.row-sub {
  font-style: italic;
  color: var(--color-paper-muted);
  margin: 0;
}
.row-arrow {
  font-size: 2rem;
  color: var(--color-gold);
  transition: transform 0.3s ease, color 0.3s ease;
}
@media (max-width: 768px) {
  .opera-row { grid-template-columns: 1fr; gap: 1rem; }
  .row-num { font-size: 1.5rem; }
  .row-img { width: 100%; }
  .row-arrow { display: none; }
}
</style>
