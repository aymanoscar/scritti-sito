---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const racconti = (await getCollection('opera'))
  .filter(o => o.data.collection === 'racconti')
  .sort((a,b) => a.data.order - b.data.order);
---

<BaseLayout title="Racconti · Ayman Soliman" description="Raccolte di racconti di AOrchestra">
  <section class="collection-hero">
    <div class="container-editorial">
      <span class="eyebrow">Raccolte</span>
      <h1>Racconti</h1>
      <p class="lead">
        Cinque raccolte di racconti scritti da AOrchestra in collaborazione con Ayman.
        Sperimentazioni narrative che spaziano per stile, registro e tema.
      </p>
    </div>
  </section>

  <section class="grid-racconti-full container-editorial">
    {racconti.map(opera => (
      <a href={`/opera/${opera.id}`} class="card">
        <div class="card-img-wrap">
          <img src={opera.data.cover} alt={opera.data.title} loading="lazy" />
          <div class="card-overlay"></div>
        </div>
        <div class="card-body">
          <span class="card-num">Raccolta {String(opera.data.order).padStart(2, '0')}</span>
          <h2 class="card-title">{opera.data.title}</h2>
          <p class="card-sub">{opera.data.subtitle}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
.collection-hero {
  padding: 8rem 0 4rem;
  text-align: center;
  background:
    radial-gradient(ellipse at center, rgba(201,169,97,0.05) 0%, transparent 60%),
    var(--color-ink);
}
.eyebrow {
  display: inline-block;
  font-family: var(--font-display);
  font-style: italic;
  color: var(--color-gold);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  font-size: 0.85rem;
  margin-bottom: 1rem;
}
.collection-hero h1 {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  margin: 0 0 1.5rem;
  color: var(--color-paper);
}
.lead {
  max-width: 56ch;
  margin: 0 auto;
  font-size: 1.2rem;
  line-height: 1.7;
  color: var(--color-paper-soft);
}

.grid-racconti-full {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  padding: 2rem 1.5rem 6rem;
}
@media (max-width: 900px) { .grid-racconti-full { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .grid-racconti-full { grid-template-columns: 1fr; } }

.card {
  display: block;
  background: var(--color-ink-card);
  border: 1px solid rgba(201,169,97,0.1);
  border-radius: 4px;
  overflow: hidden;
  text-decoration: none;
  transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
.card:hover {
  transform: translateY(-6px);
  border-color: rgba(201,169,97,0.4);
  box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}
.card-img-wrap {
  position: relative;
  aspect-ratio: 16 / 10;
  overflow: hidden;
}
.card-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.85);
  transition: transform 0.6s ease, filter 0.4s ease;
}
.card:hover .card-img-wrap img { transform: scale(1.05); filter: brightness(1); }
.card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(10,9,8,0.85) 100%);
}
.card-body { padding: 1.5rem; }
.card-num {
  font-family: var(--font-display);
  font-style: italic;
  color: var(--color-gold);
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.card-title {
  font-family: var(--font-display);
  font-size: 1.8rem;
  color: var(--color-paper);
  margin: 0.4rem 0 0.3rem;
  line-height: 1.1;
}
.card-sub {
  font-style: italic;
  color: var(--color-paper-muted);
  margin: 0;
  font-size: 1rem;
}
</style>
