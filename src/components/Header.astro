---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/libro', label: 'Libro' },
  { href: '/racconti', label: 'Racconti' },
  { href: '/about', label: 'About' },
];
const { pathname } = Astro.url;
---

<header class="site-header">
  <div class="container-editorial header-inner">
    <a href="/" class="logo">
      <span class="logo-mark">❦</span>
      <span class="logo-text">Ayman Soliman</span>
    </a>
    <nav class="nav">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={["nav-link", { active: pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10, 9, 8, 0.85);
  backdrop-filter: blur(20px) saturate(1.2);
  border-bottom: 1px solid rgba(201, 169, 97, 0.15);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.2rem 1.5rem;
}
.logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--color-paper);
  font-family: var(--font-display);
  font-size: 1.4rem;
  letter-spacing: 0.03em;
}
.logo-mark {
  color: var(--color-gold);
  font-size: 1.2rem;
  animation: shimmer 4s ease-in-out infinite;
}
.nav {
  display: flex;
  gap: 2.2rem;
}
.nav-link {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--color-paper-muted);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  position: relative;
  padding: 0.4rem 0;
  transition: color 0.25s ease;
}
.nav-link::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--color-gold);
  transition: width 0.3s ease;
}
.nav-link:hover,
.nav-link.active {
  color: var(--color-gold-bright);
}
.nav-link:hover::after,
.nav-link.active::after {
  width: 100%;
}
@media (max-width: 640px) {
  .nav { gap: 1.1rem; }
  .nav-link { font-size: 0.85rem; }
  .logo-text { display: none; }
}
</style>
